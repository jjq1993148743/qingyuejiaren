<!--pages/little-days/little-days.wxml-->
<starfield></starfield>

<view class="nav-placeholder"></view>

<scroll-view scroll-y class="page-scroll">
  <view class="container">

    <!-- 月份切换 -->
    <view class="month-header">
      <view class="month-arrow" bindtap="prevMonth">◀</view>
      <text class="month-title">{{currentYear}}年{{currentMonth}}月</text>
      <view class="month-arrow" bindtap="nextMonth">▶</view>
    </view>

    <!-- 日历 -->
    <view class="calendar glass-card">
      <!-- 星期头 -->
      <view class="cal-weekdays">
        <text class="weekday" wx:for="{{weekDays}}" wx:key="*this">{{item}}</text>
      </view>
      <!-- 日期 -->
      <view class="cal-days">
        <view 
          class="cal-day {{item.empty ? 'day-empty' : ''}} {{item.isToday ? 'day-today' : ''}} {{selectedDate === item.dateStr ? 'day-selected' : ''}} {{item.isMilestone ? 'day-milestone' : ''}}"
          wx:for="{{calendarDays}}" 
          wx:key="index"
          bindtap="onDateTap"
          data-date="{{item.dateStr}}"
          data-day="{{item.day}}"
        >
          <text class="day-num">{{item.day}}</text>
          <!-- 故事标记 -->
          <view class="day-dot story-dot" wx:if="{{item.hasStory}}"></view>
          <!-- 例假标记 -->
          <view class="day-bg period-bg" wx:if="{{item.isPeriod}}"></view>
          <view class="day-bg predicted-bg" wx:if="{{item.isPredicted}}"></view>
          <!-- 里程碑标记 -->
          <view class="day-star" wx:if="{{item.isMilestone}}">✨</view>
        </view>
      </view>
    </view>

    <!-- 日期详情区 -->
    <view class="day-detail glass-card" wx:if="{{selectedDate}}">
      <view class="detail-header">
        <text class="detail-date">{{selectedDateStr}}</text>
      </view>

      <!-- 当天故事 -->
      <view class="detail-stories" wx:if="{{dayStories.length > 0}}">
        <view class="detail-story-item" wx:for="{{dayStories}}" wx:key="_id">
          <text class="story-icon">📖</text>
          <text class="story-name">{{item.title}}</text>
        </view>
      </view>
      <view class="detail-empty" wx:else>
        <text class="empty-hint">这一天还没有故事~</text>
      </view>

      <!-- 例假操作 -->
      <view class="detail-actions">
        <view class="action-btn" bindtap="onMarkPeriod">
          <text>🩹 标记例假</text>
        </view>
        <view class="action-btn" bindtap="onPeriodSettings">
          <text>⚙️ 设置周期</text>
        </view>
        <view class="action-btn" bindtap="onCancelPeriod" wx:if="{{periodDays[selectedDate]}}">
          <text>❌ 取消标记</text>
        </view>
      </view>
    </view>

    <!-- 图例 -->
    <view class="legend glass-card">
      <view class="legend-item">
        <view class="legend-dot" style="background:#FF6B9D;"></view>
        <text class="legend-text">例假</text>
      </view>
      <view class="legend-item">
        <view class="legend-dot predicted-legend"></view>
        <text class="legend-text">预计</text>
      </view>
      <view class="legend-item">
        <view class="legend-dot" style="background:#E8B4D8;"></view>
        <text class="legend-text">有故事</text>
      </view>
      <view class="legend-item">
        <text class="legend-star">✨</text>
        <text class="legend-text">里程碑</text>
      </view>
    </view>

  </view>
</scroll-view>

<!-- 标记例假弹窗 -->
<view class="modal-mask" wx:if="{{showPeriodModal}}" bindtap="onPeriodModalClose">
  <view class="modal-content glass-card" catchtap="">
    <view class="modal-title">🩹 标记例假</view>
    <view class="modal-subtitle">{{markDate}}</view>
    <view class="modal-hint">将从该日期起标记{{periodSettings.duration}}天为例假期</view>
    <view class="modal-actions">
      <view class="btn btn-ghost" bindtap="onPeriodModalClose">取消</view>
      <view class="btn btn-primary" bindtap="onConfirmMark">确认标记</view>
    </view>
  </view>
</view>

<!-- 周期设置弹窗 -->
<view class="modal-mask" wx:if="{{showPeriodSettings}}" bindtap="onSettingsClose">
  <view class="modal-content glass-card" catchtap="">
    <view class="modal-title">⚙️ 例假周期设置</view>
    <view class="form-group">
      <text class="form-label">周期天数：{{periodSettings.cycle}}天</text>
      <slider min="0" max="14" value="{{periodSettings.cycle - 21}}" bindchange="onCycleChange" activeColor="#9B6DFF" backgroundColor="#2d1b4e" />
      <view class="slider-labels">
        <text class="slider-text">21天</text>
        <text class="slider-text">35天</text>
      </view>
    </view>
    <view class="form-group">
      <text class="form-label">持续天数：{{periodSettings.duration}}天</text>
      <slider min="0" max="4" value="{{periodSettings.duration - 3}}" bindchange="onDurationChange" activeColor="#9B6DFF" backgroundColor="#2d1b4e" />
      <view class="slider-labels">
        <text class="slider-text">3天</text>
        <text class="slider-text">7天</text>
      </view>
    </view>
    <view class="modal-actions">
      <view class="btn btn-ghost" bindtap="onSettingsClose">取消</view>
      <view class="btn btn-primary" bindtap="onSaveSettings">保存</view>
    </view>
  </view>
</view>

<music-player></music-player>
