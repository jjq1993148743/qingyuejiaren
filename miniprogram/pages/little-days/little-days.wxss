/* pages/little-days/little-days.wxss */

.page-scroll {
  height: 100vh;
}

/* 月份头 */
.month-header {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx 0 20rpx;
  gap: 40rpx;
}

.month-arrow {
  font-size: 28rpx;
  color: var(--primary-light);
  padding: 10rpx 20rpx;
}

.month-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-color);
}

/* 日历 */
.calendar {
  padding: 20rpx;
}

.cal-weekdays {
  display: flex;
  margin-bottom: 16rpx;
}

.weekday {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: var(--text-dim);
}

.cal-days {
  display: flex;
  flex-wrap: wrap;
}

.cal-day {
  width: calc(100% / 7);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 90rpx;
  position: relative;
  margin-bottom: 8rpx;
}

.day-empty {
  pointer-events: none;
}

.day-num {
  font-size: 26rpx;
  color: var(--text-color);
  z-index: 1;
}

.day-today .day-num {
  color: var(--gold-color);
  font-weight: 600;
}

.day-selected {
  background: rgba(155, 109, 255, 0.15);
  border-radius: 12rpx;
}

.day-selected .day-num {
  color: var(--primary-light);
  font-weight: 600;
}

.day-milestone .day-num {
  color: var(--gold-color);
}

/* 故事标记点 */
.day-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  position: absolute;
  bottom: 8rpx;
}

.story-dot {
  background: var(--accent-color);
}

/* 例假背景 */
.day-bg {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  right: 8rpx;
  bottom: 8rpx;
  border-radius: 12rpx;
  z-index: 0;
}

.period-bg {
  background: rgba(255, 107, 157, 0.2);
}

.predicted-bg {
  background: transparent;
  border: 1rpx dashed rgba(255, 107, 157, 0.4);
}

/* 里程碑星 */
.day-star {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  font-size: 16rpx;
}

/* 日期详情 */
.day-detail {
  margin-top: 20rpx;
  padding: 24rpx;
}

.detail-header {
  margin-bottom: 16rpx;
}

.detail-date {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-color);
}

.detail-stories {
  margin-bottom: 16rpx;
}

.detail-story-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 10rpx 0;
}

.story-icon {
  font-size: 24rpx;
}

.story-name {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.detail-empty {
  padding: 10rpx 0;
}

.empty-hint {
  font-size: 24rpx;
  color: var(--text-dim);
}

.detail-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border-glow);
}

.action-btn {
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(155, 109, 255, 0.1);
  border: 1rpx solid var(--border-glow);
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 图例 */
.legend {
  display: flex;
  justify-content: space-around;
  padding: 20rpx;
  margin-top: 20rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.predicted-legend {
  background: transparent;
  border: 1rpx dashed #FF6B9D;
}

.legend-text {
  font-size: 22rpx;
  color: var(--text-dim);
}

.legend-star {
  font-size: 18rpx;
}

/* 弹窗（复用our-story的弹窗样式） */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.6);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  width: 85%;
  padding: 40rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-color);
  text-align: center;
  margin-bottom: 12rpx;
}

.modal-subtitle {
  font-size: 26rpx;
  color: var(--accent-color);
  text-align: center;
  margin-bottom: 16rpx;
}

.modal-hint {
  font-size: 24rpx;
  color: var(--text-dim);
  text-align: center;
  margin-bottom: 24rpx;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 10rpx;
  display: block;
}

.slider-labels {
  display: flex;
  justify-content: space-between;
  margin-top: 4rpx;
}

.slider-text {
  font-size: 22rpx;
  color: var(--text-dim);
}

.modal-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.modal-actions .btn {
  flex: 1;
}
