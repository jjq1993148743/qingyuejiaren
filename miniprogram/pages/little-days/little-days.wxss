/* pages/little-days/little-days.wxss */

.page-scroll {
  height: 100vh;
}

/* 月份头 */
.month-header {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx 0 20rpx;
  gap: 40rpx;
}

.month-arrow {
  font-size: 28rpx;
  color: var(--primary-light);
  padding: 10rpx 20rpx;
}

.month-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-color);
}

/* 日历 */
.calendar {
  padding: 20rpx;
}

.cal-weekdays {
  display: flex;
  margin-bottom: 16rpx;
}

.weekday {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: var(--text-dim);
}

.cal-days {
  display: flex;
  flex-wrap: wrap;
}

.cal-day {
  width: calc(100% / 7);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 90rpx;
  position: relative;
  margin-bottom: 8rpx;
}

.day-empty {
  pointer-events: none;
}

.day-num {
  font-size: 26rpx;
  color: var(--text-color);
  z-index: 1;
}

.day-today .day-num {
  color: var(--gold-color);
  font-weight: 600;
}

.day-selected {
  background: rgba(155, 142, 196, 0.2);
  border-radius: 12rpx;
}

.day-selected .day-num {
  color: var(--primary-color);
  font-weight: 600;
}

.day-milestone .day-num {
  color: var(--gold-color);
}

/* 标记点 */
.day-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  position: absolute;
  bottom: 8rpx;
}

.completed-dot {
  background: #4CAF50;
}

.todo-dot {
  background: #9B8EC4;
  opacity: 0.6;
}

/* 例假背景 */
.day-bg {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  right: 8rpx;
  bottom: 8rpx;
  border-radius: 12rpx;
  z-index: 0;
}

.period-bg {
  background: rgba(255, 107, 157, 0.2);
}

/* 里程碑星 */
.day-star {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  font-size: 16rpx;
}

/* 日期详情 */
.day-detail {
  margin-top: 20rpx;
  padding: 24rpx;
}

.detail-header {
  margin-bottom: 16rpx;
}

.detail-date {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-color);
}

/* 详情列表 */
.detail-items {
  margin-bottom: 16rpx;
}

.detail-item {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
  gap: 12rpx;
  border-bottom: 1rpx solid rgba(155, 142, 196, 0.12);
}

.detail-item:last-child {
  border-bottom: none;
}

.detail-item.milestone,
.detail-item.period {
  cursor: default;
}

.detail-item.completed,
.detail-item.todo {
  cursor: pointer;
}

.detail-item-icon {
  flex-shrink: 0;
  font-size: 24rpx;
  width: 40rpx;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 未完成：空心圆圈 */
.checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid var(--primary-light);
  border-radius: 50%;
  position: relative;
}

.checkbox .check-mark {
  position: absolute;
  left: 12rpx;
  top: 5rpx;
  width: 10rpx;
  height: 20rpx;
  border: 2rpx solid var(--primary-light);
  border-width: 0 2rpx 2rpx 0;
  transform: rotate(45deg);
  opacity: 0.3;
}

/* 已完成：绿色圆圈勾号 */
.checkbox-checked {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #4CAF50;
  border-radius: 50%;
  background: rgba(76, 175, 80, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #4CAF50;
  font-size: 22rpx;
}

.detail-item-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.detail-item-title {
  font-size: 26rpx;
  color: var(--text-color);
}

.detail-item-sub {
  font-size: 22rpx;
  color: var(--text-dim);
  font-style: italic;
}

.detail-item-arrow {
  flex-shrink: 0;
}

.arrow-text {
  font-size: 32rpx;
  color: var(--text-dim);
}

.detail-empty {
  padding: 10rpx 0;
}

.empty-hint {
  font-size: 24rpx;
  color: var(--text-dim);
}

.detail-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border-glow);
}

.action-btn {
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(155, 142, 196, 0.08);
  border: 1rpx solid var(--border-glow);
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 图例 */
.legend {
  display: flex;
  justify-content: space-around;
  padding: 20rpx;
  margin-top: 20rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.todo-legend {
  background: #9B8EC4;
  opacity: 0.6;
}

.legend-text {
  font-size: 22rpx;
  color: var(--text-dim);
}

.legend-star {
  font-size: 18rpx;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.6);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  width: 85%;
  max-height: 80vh;
  overflow-y: auto;
  padding: 40rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-color);
  text-align: center;
  margin-bottom: 12rpx;
}

.modal-subtitle {
  font-size: 26rpx;
  color: var(--accent-color);
  text-align: center;
  margin-bottom: 16rpx;
}

.modal-hint {
  font-size: 24rpx;
  color: var(--text-dim);
  text-align: center;
  margin-bottom: 24rpx;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 10rpx;
  display: block;
}

.form-input {
  background: rgba(155, 142, 196, 0.06);
  border: 1rpx solid var(--border-glow);
  border-radius: 16rpx;
  padding: 20rpx;
  color: var(--text-color);
  font-size: 28rpx;
}

.form-textarea {
  background: rgba(155, 142, 196, 0.08);
  border: 1rpx solid var(--border-glow);
  border-radius: 16rpx;
  padding: 20rpx;
  color: var(--text-color);
  font-size: 28rpx;
  min-height: 160rpx;
  width: 100%;
  box-sizing: border-box;
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.image-item {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.preview-img {
  width: 100%;
  height: 100%;
}

.slider-labels {
  display: flex;
  justify-content: space-between;
  margin-top: 4rpx;
}

.slider-text {
  font-size: 22rpx;
  color: var(--text-dim);
}

.modal-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.modal-actions .btn {
  flex: 1;
  height: 72rpx;
  font-size: 26rpx;
}

.feeling-textarea {
  min-height: 120rpx;
}

.date-picker {
  color: var(--text-color);
}

.image-add {
  width: 120rpx;
  height: 120rpx;
  border: 2rpx dashed var(--border-glow);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-icon {
  font-size: 52rpx;
  color: var(--primary-light);
}

.image-remove {
  position: absolute;
  top: 0;
  right: 0;
  width: 36rpx;
  height: 36rpx;
  background: rgba(255, 0, 0, 0.6);
  color: #fff;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0 12rpx 0 12rpx;
}
