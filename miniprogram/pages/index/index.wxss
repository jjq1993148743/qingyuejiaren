/* pages/index/index.wxss */

.page-scroll {
  height: 100vh;
}

/* 英雄区 */
.hero-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 30rpx;
}

.hero-names {
  font-size: 36rpx;
  color: var(--accent-color);
  margin-bottom: 16rpx;
  letter-spacing: 4rpx;
}

.hero-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.hero-days {
  display: flex;
  align-items: baseline;
  justify-content: center;
}

.days-number {
  font-size: 120rpx;
  font-weight: 700;
  color: var(--gold-color);
  text-shadow: 0 0 40rpx rgba(255, 215, 0, 0.4);
  animation: dayGlow 3s ease-in-out infinite alternate;
  line-height: 1.1;
}

.days-unit {
  font-size: 36rpx;
  color: var(--text-secondary);
  margin-left: 8rpx;
}

@keyframes dayGlow {
  0% { text-shadow: 0 0 20rpx rgba(255, 215, 0, 0.3); }
  100% { text-shadow: 0 0 60rpx rgba(255, 215, 0, 0.6); }
}

.hero-milestone {
  margin-top: 16rpx;
}

.milestone-badge {
  background: linear-gradient(135deg, rgba(255, 215, 0, 0.2), rgba(232, 180, 216, 0.2));
  border: 1rpx solid var(--gold-color);
  border-radius: 30rpx;
  padding: 8rpx 24rpx;
  font-size: 26rpx;
  color: var(--gold-color);
}

/* 里程碑进度条 */
.milestone-track {
  padding: 30rpx 20rpx;
}

.track-line {
  height: 4rpx;
  background: rgba(155, 109, 255, 0.2);
  border-radius: 2rpx;
  position: relative;
  margin-bottom: 20rpx;
}

.track-fill {
  position: absolute;
  height: 100%;
  background: linear-gradient(90deg, var(--primary-color), var(--accent-color));
  border-radius: 2rpx;
  transition: width 0.5s ease;
}

.milestone-dots {
  display: flex;
  justify-content: space-between;
  overflow-x: auto;
  padding-bottom: 10rpx;
}

.milestone-dot {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 70rpx;
}

.dot {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid var(--text-dim);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  margin-bottom: 8rpx;
  transition: all 0.3s;
}

.dot-active {
  border-color: var(--gold-color);
  box-shadow: 0 0 16rpx rgba(255, 215, 0, 0.4);
  background: rgba(255, 215, 0, 0.1);
}

.dot-label {
  font-size: 20rpx;
  color: var(--text-dim);
}

.milestone-dot.reached .dot-label {
  color: var(--text-secondary);
}

/* ==================== 微信对话区 ==================== */
.chat-section {
  margin-bottom: 30rpx;
}

.chat-date-label {
  text-align: center;
  font-size: 24rpx;
  color: var(--text-dim);
  margin-bottom: 20rpx;
  padding: 8rpx 24rpx;
  background: rgba(155, 109, 255, 0.08);
  border-radius: 20rpx;
  display: inline-block;
  margin-left: 50%;
  transform: translateX(-50%);
}

/* 对话气泡 */
.chat-bubble {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
  gap: 16rpx;
}

.chat-bubble.left {
  flex-direction: row;
}

.chat-bubble.right {
  flex-direction: row-reverse;
}

.chat-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
  background: rgba(155, 109, 255, 0.15);
  border: 1rpx solid var(--border-glow);
}

/* 左侧气泡（🌙） */
.chat-bubble.left .bubble-content {
  background: rgba(155, 109, 255, 0.15);
  border: 1rpx solid rgba(155, 109, 255, 0.2);
  border-radius: 4rpx 20rpx 20rpx 20rpx;
  padding: 20rpx 24rpx;
  max-width: 75%;
  position: relative;
}

.chat-bubble.left .bubble-content::before {
  content: '';
  position: absolute;
  left: -16rpx;
  top: 20rpx;
  width: 0;
  height: 0;
  border-top: 10rpx solid transparent;
  border-bottom: 10rpx solid transparent;
  border-right: 16rpx solid rgba(155, 109, 255, 0.15);
}

/* 右侧气泡（🌞） */
.chat-bubble.right .bubble-content {
  background: rgba(232, 180, 216, 0.15);
  border: 1rpx solid rgba(232, 180, 216, 0.2);
  border-radius: 20rpx 4rpx 20rpx 20rpx;
  padding: 20rpx 24rpx;
  max-width: 75%;
  position: relative;
}

.chat-bubble.right .bubble-content::before {
  content: '';
  position: absolute;
  right: -16rpx;
  top: 20rpx;
  width: 0;
  height: 0;
  border-top: 10rpx solid transparent;
  border-bottom: 10rpx solid transparent;
  border-left: 16rpx solid rgba(232, 180, 216, 0.15);
}

.bubble-content text {
  font-size: 28rpx;
  color: var(--text-color);
  line-height: 1.8;
}

/* ==================== 我们的家 ==================== */
.home-section {
  position: relative;
  overflow: hidden;
}

.home-section::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 6rpx;
  height: 100%;
  background: linear-gradient(180deg, var(--primary-color), var(--accent-color));
  border-radius: 3rpx;
}

.home-header {
  font-size: 30rpx;
  color: var(--accent-color);
  font-weight: 600;
  margin-bottom: 20rpx;
}

.home-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.home-item-text {
  font-size: 28rpx;
  color: var(--text-color);
  line-height: 1.8;
}

.home-expand {
  text-align: center;
  margin-top: 20rpx;
  padding: 10rpx;
}

.home-expand text {
  color: var(--primary-light);
  font-size: 26rpx;
}

/* 最后的承诺 */
.final-section {
  margin-bottom: 20rpx;
}

.final-card {
  border: 1rpx solid var(--accent-warm);
}

.final-highlight {
  font-size: 30rpx;
  color: var(--accent-warm);
  font-weight: 600;
  line-height: 1.8;
}

/* 烟花效果 */
.firework-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 999;
  pointer-events: none;
}

.firework {
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  animation: fireworkBurst 2s ease-out forwards;
}

.f1 { left: 30%; top: 30%; animation-delay: 0s; background: #FF6B9D; box-shadow: 0 0 20rpx #FF6B9D; }
.f2 { left: 60%; top: 25%; animation-delay: 0.3s; background: #FFD700; box-shadow: 0 0 20rpx #FFD700; }
.f3 { left: 45%; top: 40%; animation-delay: 0.6s; background: #9B6DFF; box-shadow: 0 0 20rpx #9B6DFF; }
.f4 { left: 20%; top: 35%; animation-delay: 0.9s; background: #FF8C69; box-shadow: 0 0 20rpx #FF8C69; }
.f5 { left: 70%; top: 45%; animation-delay: 1.2s; background: #E8B4D8; box-shadow: 0 0 20rpx #E8B4D8; }

@keyframes fireworkBurst {
  0% { transform: scale(0); opacity: 1; }
  30% { transform: scale(8); opacity: 1; }
  100% { transform: scale(15); opacity: 0; }
}
