<!--pages/index/index.wxml-->
<starfield showMoon="{{true}}"></starfield>

<view class="nav-placeholder"></view>

<scroll-view scroll-y class="page-scroll">
  <view class="container">

    <!-- 在一起天数 -->
    <view class="hero-section">
      <view class="hero-names">🌙 伍月er &amp; 🌞</view>
      <view class="hero-label">在一起</view>
      <view class="hero-days">
        <text class="days-number">{{days}}</text>
        <text class="days-unit">天</text>
      </view>
      <view class="hero-milestone" wx:if="{{currentMilestone}}">
        <text class="milestone-badge">{{currentMilestone.icon}} {{currentMilestone.label}}</text>
      </view>
    </view>

    <!-- 里程碑进度条 -->
    <view class="milestone-track glass-card">
      <view class="track-line">
        <view class="track-fill" style="width:{{currentMilestone ? ((currentMilestone.days / milestones[milestones.length-1].days) * 100) : 0}}%"></view>
      </view>
      <view class="milestone-dots">
        <view 
          wx:for="{{milestones}}" 
          wx:key="days"
          class="milestone-dot {{item.reached ? 'reached' : ''}}"
          bindtap="onMilestoneTap"
          data-index="{{index}}"
        >
          <view class="dot {{item.reached ? 'dot-active' : ''}}">
            <text wx:if="{{item.reached}}">{{item.icon}}</text>
          </view>
          <text class="dot-label">{{item.days}}</text>
        </view>
      </view>
    </view>

    <!-- 微信对话区 - 初见 -->
    <view class="chat-section">
      <view class="chat-date-label">3月10日 · 初见</view>
      <view class="chat-bubble left">
        <view class="chat-avatar">🌙</view>
        <view class="bubble-content">
          <text>我是🌙</text>
        </view>
      </view>
      <view class="chat-bubble left">
        <view class="chat-avatar">🌙</view>
        <view class="bubble-content">
          <text>伍月er🌞 你好~</text>
        </view>
      </view>
    </view>

    <!-- 微信对话区 - 欢喜 -->
    <view class="chat-section">
      <view class="chat-date-label">3月25日 · 欢喜</view>
      <view class="chat-bubble left">
        <view class="chat-avatar">🌙</view>
        <view class="bubble-content">
          <text>我想跟你处对象，我等你答应我</text>
        </view>
      </view>
      <view class="chat-bubble right">
        <view class="bubble-content">
          <text>我看到了</text>
        </view>
        <view class="chat-avatar">🌞</view>
      </view>
    </view>

    <!-- 微信对话区 - 锁定 -->
    <view class="chat-section">
      <view class="chat-date-label">4月12日 · 锁定</view>
      <view class="chat-bubble left">
        <view class="chat-avatar">🌙</view>
        <view class="bubble-content">
          <text>只要你不出轨，不家暴，我跟定你了，我一定要和你在平淡的日子里开出花。</text>
        </view>
      </view>
      <view class="chat-bubble left">
        <view class="chat-avatar">🌙</view>
        <view class="bubble-content">
          <text>我一定会好好经营我们在一起的生活，这是我给自己的承诺。</text>
        </view>
      </view>
      <view class="chat-bubble left">
        <view class="chat-avatar">🌙</view>
        <view class="bubble-content">
          <text>我会在你看不见我的地方忠诚于你，和你一起经营我们的生活，让你下班有期待，生活有情调，和你一起孝顺父母，这是我给你的承诺。</text>
        </view>
      </view>
    </view>

    <!-- 我们的家 -->
    <view class="home-section glass-card">
      <view class="home-header">🏠 我们的家</view>
      <view class="home-list">
        <view 
          wx:for="{{homeExpanded ? ourHome : ourHome.slice(0, 4)}}" 
          wx:key="index"
          class="home-item"
        >
          <text class="home-item-text">⬛️ {{item}}</text>
        </view>
      </view>
      <view class="home-expand" bindtap="toggleHome">
        <text>{{homeExpanded ? '收起 ▲' : '展开全文 ▼'}}</text>
      </view>
    </view>

    <!-- 最后的承诺 -->
    <view class="final-section" wx:if="{{homeExpanded}}">
      <view class="final-card glass-card">
        <text class="final-highlight">最后，我们的家，是我们两个人的，至于爱情的结晶？他得排在我媳妇儿后边，谁也不行！</text>
      </view>
    </view>

  </view>
</scroll-view>

<!-- 烟花效果 -->
<view class="firework-overlay" wx:if="{{showFirework}}">
  <view class="firework f1"></view>
  <view class="firework f2"></view>
  <view class="firework f3"></view>
  <view class="firework f4"></view>
  <view class="firework f5"></view>
</view>

<!-- 音乐播放器 -->
<music-player></music-player>
