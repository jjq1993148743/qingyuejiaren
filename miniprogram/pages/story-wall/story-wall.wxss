/* pages/story-wall/story-wall.wxss */

/* 月亮 */
.moon-wrap {
  position: fixed;
  top: 80rpx;
  right: 60rpx;
  width: 120rpx;
  height: 120rpx;
  z-index: -1;
  pointer-events: none;
}

.moon-body {
  position: absolute;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #F5F0FF, #E8D8F8);
  box-shadow: 0 0 60rpx rgba(200, 180, 255, 0.5), 0 0 120rpx rgba(155, 142, 196, 0.25);
}

.moon-shadow {
  position: absolute;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #1E1538;
  top: -20rpx;
  left: 20rpx;
}

.moon-glow {
  position: absolute;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(200, 180, 255, 0.25) 0%, transparent 70%);
  top: -40rpx;
  left: -40rpx;
  animation: moonPulse 4s ease-in-out infinite alternate;
}

@keyframes moonPulse {
  0% { transform: scale(1); opacity: 0.6; }
  100% { transform: scale(1.2); opacity: 1; }
}

.page-scroll {
  height: 100vh;
}

.page-header {
  padding: 30rpx 0 20rpx;
}

.page-title {
  font-size: 38rpx;
  font-weight: 600;
  color: var(--text-color);
}

/* ==================== 在一起天数 ==================== */
.hero-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0 30rpx;
}

.hero-days-row {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 8rpx;
}

.hero-label {
  font-size: 32rpx;
  color: var(--text-secondary);
}

.days-number {
  font-size: 100rpx;
  font-weight: 700;
  color: #FFD700;
  text-shadow: 0 0 40rpx rgba(255, 215, 0, 0.5), 0 0 80rpx rgba(255, 200, 0, 0.25), 0 2rpx 8rpx rgba(0,0,0,0.3);
  animation: heartbeat 1.5s ease-in-out infinite;
  line-height: 1.1;
  transform-origin: center center;
}

.days-unit {
  font-size: 32rpx;
  color: var(--text-secondary);
}

@keyframes heartbeat {
  0% { transform: scale(1); }
  14% { transform: scale(1.15); }
  28% { transform: scale(1); }
  42% { transform: scale(1.1); }
  56% { transform: scale(1); }
  100% { transform: scale(1); }
}

.hero-milestone {
  margin-top: 16rpx;
}

.milestone-badge {
  background: linear-gradient(135deg, rgba(155, 142, 196, 0.25), rgba(212, 165, 201, 0.2));
  border: 1rpx solid var(--primary-light);
  border-radius: 30rpx;
  padding: 8rpx 24rpx;
  font-size: 26rpx;
  color: var(--primary-light);
}

/* ==================== 里程碑进度条 ==================== */
.milestone-track {
  padding: 30rpx 20rpx;
}

.track-line {
  height: 4rpx;
  background: rgba(155, 142, 196, 0.2);
  border-radius: 2rpx;
  position: relative;
  margin-bottom: 20rpx;
}

.track-fill {
  position: absolute;
  height: 100%;
  background: linear-gradient(90deg, var(--primary-color), var(--accent-color));
  border-radius: 2rpx;
  transition: width 0.5s ease;
}

.milestone-dots {
  display: flex;
  justify-content: space-between;
  overflow-x: auto;
  padding-bottom: 10rpx;
}

.milestone-dot {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 70rpx;
}

.dot {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid var(--text-dim);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  margin-bottom: 8rpx;
  transition: all 0.3s;
}

.dot-active {
  border-color: var(--primary-color);
  box-shadow: 0 0 16rpx rgba(155, 142, 196, 0.45);
  background: rgba(155, 142, 196, 0.2);
}

.dot-label {
  font-size: 20rpx;
  color: var(--text-dim);
}

.milestone-dot.reached .dot-label {
  color: var(--text-secondary);
}

/* 时间线 */
.timeline {
  padding-left: 20rpx;
}

.timeline-item {
  display: flex;
  flex-direction: row;
  margin-bottom: 10rpx;
  position: relative;
}

.timeline-node {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100rpx;
  flex-shrink: 0;
  padding-top: 30rpx;
}

.node-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #4CAF50;
  box-shadow: 0 0 12rpx rgba(76, 175, 80, 0.5);
  margin-bottom: 10rpx;
  position: relative;
  z-index: 1;
}

/* 竖线 */
.timeline-item:not(:last-child) .node-dot::after {
  content: '';
  position: absolute;
  top: 20rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 4rpx;
  height: 300rpx;
  background: linear-gradient(180deg, var(--border-glow), transparent);
}

.node-date {
  font-size: 22rpx;
  color: var(--text-dim);
  white-space: nowrap;
}

.timeline-content {
  flex: 1;
  padding-left: 10rpx;
}

.story-card {
  padding: 24rpx;
}

.story-title {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-color);
  margin-bottom: 16rpx;
}

/* 九宫格图片 */
.story-images {
  display: grid;
  gap: 8rpx;
  margin-bottom: 16rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.grid-one {
  grid-template-columns: 1fr;
  max-height: 400rpx;
}

.grid-two {
  grid-template-columns: 1fr 1fr;
}

.grid-four {
  grid-template-columns: 1fr 1fr;
}

.grid-nine {
  grid-template-columns: 1fr 1fr 1fr;
}

.img-cell {
  overflow: hidden;
}

.grid-one .img-cell {
  height: 400rpx;
}

.grid-two .img-cell {
  height: 200rpx;
}

.grid-four .img-cell {
  height: 200rpx;
}

.grid-nine .img-cell {
  height: 160rpx;
}

.grid-img {
  width: 100%;
  height: 100%;
}

.story-preview {
  padding: 0;
}

.preview-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  font-style: italic;
}

/* ==================== 我们的家 - 聊天记录 ==================== */
.chat-section {
  margin-bottom: 30rpx;
}

.chat-date-label {
  text-align: center;
  font-size: 24rpx;
  color: var(--text-dim);
  margin-bottom: 20rpx;
  padding: 8rpx 24rpx;
  background: rgba(155, 142, 196, 0.12);
  border-radius: 20rpx;
  display: inline-block;
  margin-left: 50%;
  transform: translateX(-50%);
}

/* 对话气泡 */
.chat-bubble {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
  gap: 16rpx;
}

.chat-bubble.left {
  flex-direction: row;
}

.chat-bubble.right {
  flex-direction: row;
  justify-content: flex-end;
}

.chat-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.avatar-she {
  background: linear-gradient(135deg, #9B8EC4, #7B6EA8);
  color: #ffffff;
  border: 2rpx solid rgba(155, 142, 196, 0.5);
  box-shadow: 0 0 16rpx rgba(155, 142, 196, 0.35);
}

.avatar-he {
  background: linear-gradient(135deg, #D4A5C9, #C48EC4);
  color: #ffffff;
  border: 2rpx solid rgba(196, 142, 196, 0.5);
  box-shadow: 0 0 16rpx rgba(196, 142, 196, 0.35);
}

/* 左侧气泡（女） */
.chat-bubble.left .bubble-content {
  background: rgba(155, 142, 196, 0.15);
  border: 1rpx solid rgba(155, 142, 196, 0.25);
  border-radius: 4rpx 20rpx 20rpx 20rpx;
  padding: 20rpx 24rpx;
  max-width: 75%;
  position: relative;
}

.chat-bubble.left .bubble-content::before {
  content: '';
  position: absolute;
  left: -16rpx;
  top: 20rpx;
  width: 0;
  height: 0;
  border-top: 10rpx solid transparent;
  border-bottom: 10rpx solid transparent;
  border-right: 16rpx solid rgba(155, 142, 196, 0.15);
}

/* 右侧气泡（男） */
.chat-bubble.right .bubble-content {
  background: rgba(196, 142, 196, 0.15);
  border: 1rpx solid rgba(196, 142, 196, 0.25);
  border-radius: 20rpx 4rpx 20rpx 20rpx;
  padding: 20rpx 24rpx;
  max-width: 75%;
  position: relative;
}

.chat-bubble.right .bubble-content::before {
  content: '';
  position: absolute;
  right: -16rpx;
  top: 20rpx;
  width: 0;
  height: 0;
  border-top: 10rpx solid transparent;
  border-bottom: 10rpx solid transparent;
  border-left: 16rpx solid rgba(196, 142, 196, 0.15);
}

.bubble-content text {
  font-size: 28rpx;
  color: var(--text-color);
  line-height: 1.8;
}

/* 气泡内的"我们的家" */
.bubble-home {
  padding: 20rpx 24rpx 10rpx !important;
}

.home-title {
  font-size: 28rpx;
  color: var(--accent-color);
  font-weight: 600;
  margin-bottom: 16rpx;
}

.home-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.home-item text {
  font-size: 26rpx;
  color: var(--text-color);
  line-height: 1.6;
}

.home-final {
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(212, 165, 201, 0.2);
}

.home-final text {
  font-size: 28rpx;
  color: var(--accent-color);
  font-weight: 600;
  line-height: 1.8;
}

/* 分隔线 */
.section-divider {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin: 40rpx 0 30rpx;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, var(--primary-color), transparent);
  opacity: 0.3;
}

.divider-text {
  font-size: 24rpx;
  color: var(--text-dim);
  white-space: nowrap;
}


