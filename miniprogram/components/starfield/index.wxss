/* components/starfield/index.wxss */

.starfield {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
  overflow: hidden;
  pointer-events: none;
}

.sky-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg, #1a0033 0%, #2d1b4e 50%, #3a1f5e 100%);
}

/* 星星 */
.star {
  position: absolute;
  border-radius: 50%;
  background: #ffffff;
  animation: twinkle 3s ease-in-out infinite alternate;
}

.star-1 { width: 2rpx; height: 2rpx; }
.star-2 { width: 4rpx; height: 4rpx; }
.star-3 { width: 6rpx; height: 6rpx; }

@keyframes twinkle {
  0% { opacity: 0.3; }
  100% { opacity: 1; }
}

/* 月亮 */
.moon {
  position: absolute;
  top: 80rpx;
  right: 60rpx;
  width: 120rpx;
  height: 120rpx;
}

.moon-body {
  position: absolute;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFF8DC, #FFE4B5);
  box-shadow: 0 0 40rpx rgba(255, 248, 220, 0.6);
}

.moon-shadow {
  position: absolute;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #1a0033;
  top: -20rpx;
  left: 20rpx;
}

.moon-glow {
  position: absolute;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 248, 220, 0.15) 0%, transparent 70%);
  top: -40rpx;
  left: -40rpx;
  animation: moonPulse 4s ease-in-out infinite alternate;
}

@keyframes moonPulse {
  0% { transform: scale(1); opacity: 0.6; }
  100% { transform: scale(1.2); opacity: 1; }
}

/* 流星 */
.shooting-star {
  position: absolute;
  width: 200rpx;
  height: 4rpx;
  transform: rotate(35deg);
  animation: shootStar 1.5s linear forwards;
}

.meteor-head {
  position: absolute;
  left: 0;
  top: 0;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #ffffff;
  box-shadow: 0 0 10rpx #ffffff, 0 0 20rpx rgba(155, 109, 255, 0.5);
}

.meteor-tail {
  position: absolute;
  left: 8rpx;
  top: 0;
  width: 192rpx;
  height: 4rpx;
  background: linear-gradient(to right, rgba(255, 255, 255, 0.8), transparent);
  border-radius: 2rpx;
}

@keyframes shootStar {
  0% {
    transform: rotate(35deg) translateX(0);
    opacity: 1;
  }
  100% {
    transform: rotate(35deg) translateX(600rpx);
    opacity: 0;
  }
}
