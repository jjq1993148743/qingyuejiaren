/* components/wish-edit-modal/index.wxss */

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.6);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  width: 88%;
  max-height: 70vh;
  overflow-y: auto;
  padding: 30rpx 28rpx;
  background: #2A1F48 !important;
  border: 1rpx solid var(--border-glow);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.5);
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-color);
  text-align: center;
  margin-bottom: 8rpx;
}

.form-group {
  margin-bottom: 16rpx;
}

.form-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 6rpx;
  display: block;
}

.form-input {
  background: rgba(155, 142, 196, 0.12);
  border: 1rpx solid var(--border-glow);
  border-radius: 16rpx;
  padding: 16rpx;
  color: var(--text-color);
  font-size: 26rpx;
}

.form-textarea {
  background: rgba(155, 142, 196, 0.12);
  border: 1rpx solid var(--border-glow);
  border-radius: 16rpx;
  padding: 16rpx;
  color: var(--text-color);
  font-size: 26rpx;
  min-height: 80rpx;
  width: 100%;
  box-sizing: border-box;
}

.title-textarea {
  height: 100rpx;
}

.feeling-textarea {
  height: 160rpx;
}

.date-picker {
  color: var(--text-color);
}

.date-picker.disabled {
  opacity: 0.5;
  pointer-events: none;
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.preview-img {
  width: 100%;
  height: 100%;
}

.modal-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(155, 142, 196, 0.15);
}

.action-btn {
  flex: 1;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  border-radius: 38rpx;
  font-weight: 500;
  transition: all 0.2s;
}

/* 取消按钮 */
.action-cancel {
  background: rgba(155, 142, 196, 0.12);
  border: 1rpx solid rgba(155, 142, 196, 0.3);
  color: var(--text-secondary);
}

.action-cancel:active {
  background: rgba(155, 142, 196, 0.2);
  transform: scale(0.97);
}

/* 保存按钮 */
.action-save {
  background: linear-gradient(135deg, #D4A5C9, #E8C4A0);
  border: none;
  color: #1E1538;
  font-weight: 600;
  box-shadow: 0 6rpx 20rpx rgba(212, 165, 201, 0.35);
}

.action-save:active {
  opacity: 0.85;
  transform: scale(0.97);
}
