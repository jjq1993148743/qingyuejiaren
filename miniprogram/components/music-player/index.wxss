/* components/music-player/index.wxss - 淡紫星空主题 */

.music-fab {
  position: fixed;
  right: 30rpx;
  bottom: calc(env(safe-area-inset-bottom) + 130rpx);
  z-index: 100;
  width: 100rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 唱片盘 */
.disc {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #2E2450, #3D3268);
  border: 3rpx solid rgba(155, 142, 196, 0.4);
  box-shadow: 0 4rpx 24rpx rgba(155, 142, 196, 0.25), inset 0 0 20rpx rgba(155, 142, 196, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  transition: box-shadow 0.3s;
}

.disc.spinning {
  animation: discSpin 4s linear infinite;
  box-shadow: 0 4rpx 32rpx rgba(155, 142, 196, 0.4), inset 0 0 20rpx rgba(155, 142, 196, 0.15);
}

@keyframes discSpin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 唱片纹理 */
.disc-inner {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(155, 142, 196, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.disc-ring {
  position: absolute;
  width: 54rpx;
  height: 54rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(155, 142, 196, 0.2);
}

/* 唱片中心 */
.disc-center {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #9B8EC4, #D4A5C9);
  display: flex;
  align-items: center;
  justify-content: center;
}

.disc-note {
  font-size: 18rpx;
  color: #fff;
  line-height: 1;
}

/* 飘音符 */
.notes-container {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

.float-note {
  position: absolute;
  font-size: 24rpx;
  color: rgba(155, 142, 196, 0.8);
  animation: noteFloat 3s ease-out infinite;
}

.n1 {
  left: -10rpx;
  top: -10rpx;
  animation-delay: 0s;
  color: rgba(212, 165, 201, 0.9);
}

.n2 {
  left: 30rpx;
  top: -20rpx;
  animation-delay: 1s;
  font-size: 28rpx;
  color: rgba(155, 142, 196, 0.9);
}

.n3 {
  left: 60rpx;
  top: -5rpx;
  animation-delay: 2s;
  color: rgba(200, 180, 255, 0.8);
}

@keyframes noteFloat {
  0% {
    opacity: 1;
    transform: translateY(0) scale(1) rotate(0deg);
  }
  50% {
    opacity: 0.6;
    transform: translateY(-60rpx) scale(1.2) rotate(15deg);
  }
  100% {
    opacity: 0;
    transform: translateY(-120rpx) scale(0.6) rotate(-10deg);
  }
}

/* 播放按钮（暂停状态） */
.play-indicator {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  pointer-events: none;
}

.play-triangle {
  width: 0;
  height: 0;
  border-top: 14rpx solid transparent;
  border-bottom: 14rpx solid transparent;
  border-left: 22rpx solid rgba(200, 180, 255, 0.85);
  margin-left: 6rpx;
}
