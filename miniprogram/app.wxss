@keyframes twinkle {
  0%, 100% { opacity: 0.1; transform: scale(0.6); }
  50%      { opacity: 1;   transform: scale(1.4); }
}

/* ==================== 流星效果 ==================== */
.meteor-layer {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
  pointer-events: none;
  overflow: hidden;
}

.meteor {
  position: absolute;
  width: 2rpx;
  height: 2rpx;
  background: #fff;
  border-radius: 50%;
  box-shadow: 0 0 6rpx 2rpx rgba(255,255,255,0.6);
  opacity: 0;
}

/* 流星拖尾 - 用::after做光线尾巴 */
.meteor::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 120rpx;
  height: 2rpx;
  background: linear-gradient(90deg, rgba(255,255,255,0.6), transparent);
  transform-origin: left center;
  transform: rotate(0deg);
}

/* 三颗流星，不同位置和时序 */
.meteor-1 {
  top: 5%;
  left: 15%;
  transform: rotate(-35deg);
  animation: meteor1 6s 0s linear infinite;
}
.meteor-1::after {
  transform: rotate(0deg);
}

.meteor-2 {
  top: 2%;
  left: 55%;
  transform: rotate(-35deg);
  animation: meteor2 8s 2s linear infinite;
}
.meteor-2::after {
  transform: rotate(0deg);
}

.meteor-3 {
  top: 8%;
  left: 80%;
  transform: rotate(-35deg);
  animation: meteor3 7s 4s linear infinite;
}
.meteor-3::after {
  transform: rotate(0deg);
}

@keyframes meteor1 {
  0% { opacity: 0; transform: rotate(-35deg) translate(0, 0); }
  5% { opacity: 1; }
  30% { opacity: 1; }
  40% { opacity: 0; transform: rotate(-35deg) translate(500rpx, 350rpx); }
  100% { opacity: 0; transform: rotate(-35deg) translate(500rpx, 350rpx); }
}

@keyframes meteor2 {
  0% { opacity: 0; transform: rotate(-35deg) translate(0, 0); }
  5% { opacity: 1; }
  25% { opacity: 1; }
  35% { opacity: 0; transform: rotate(-35deg) translate(600rpx, 420rpx); }
  100% { opacity: 0; transform: rotate(-35deg) translate(600rpx, 420rpx); }
}

@keyframes meteor3 {
  0% { opacity: 0; transform: rotate(-35deg) translate(0, 0); }
  5% { opacity: 1; }
  28% { opacity: 1; }
  38% { opacity: 0; transform: rotate(-35deg) translate(450rpx, 315rpx); }
  100% { opacity: 0; transform: rotate(-35deg) translate(450rpx, 315rpx); }
}

/* 自定义导航栏占位 */
.nav-placeholder {
  height: 44px;
  width: 100%;
}

/* 通用容器 */
.container {
  padding: 0 30rpx;
  box-sizing: border-box;
  padding-bottom: 220rpx;
}

/* 毛玻璃卡片 - 星空主题 */
.glass-card {
  background: rgba(40, 30, 65, 0.6);
  border: 1rpx solid rgba(155, 142, 196, 0.25);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.2);
}

.glass-card-glow {
  background: rgba(40, 30, 65, 0.6);
  border: 1rpx solid var(--primary-light);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(155, 142, 196, 0.15);
}

/* 按钮 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  padding: 0 40rpx;
  font-weight: 500;
  transition: all 0.3s ease;
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary-color), var(--accent-color));
  color: var(--white);
  box-shadow: 0 8rpx 24rpx rgba(155, 142, 196, 0.3);
}

.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.97);
}

.btn-ghost {
  background: transparent;
  color: var(--primary-color);
  border: 1rpx solid var(--primary-color);
}

/* 文本样式 */
.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-color);
  margin-bottom: 20rpx;
}

.text-secondary {
  color: var(--text-secondary);
}

.text-dim {
  color: var(--text-dim);
}

.text-accent {
  color: var(--accent-color);
}

.text-gold {
  color: var(--gold-color);
}

.text-center {
  text-align: center;
}

/* 分隔线 */
.divider {
  width: 100%;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, var(--border-glow), transparent);
  margin: 30rpx 0;
}

.divider-label {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 30rpx 0;
}

.divider-label::before,
.divider-label::after {
  content: '';
  flex: 1;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, var(--border-glow), transparent);
}

.divider-label text {
  padding: 0 20rpx;
  color: var(--text-dim);
  font-size: 24rpx;
}

/* Flex 辅助 */
.flex-row { display: flex; flex-direction: row; }
.flex-column { display: flex; flex-direction: column; }
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-wrap { flex-wrap: wrap; }
.flex-1 { flex: 1; }

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
}

.empty-state .empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-state .empty-text {
  color: var(--text-dim);
  font-size: 28rpx;
}

/* 安全区域 */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* 滚动条隐藏 */
::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
  color: transparent;
}
