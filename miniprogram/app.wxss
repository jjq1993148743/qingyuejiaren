/**app.wxss - 清悦佳人全局样式 - 淡紫星空主题**/

page {
  --primary-color: #9B8EC4;
  --primary-light: #B5A8D4;
  --accent-color: #D4A5C9;
  --accent-warm: #C48EC4;
  --gold-color: #C9B896;
  --text-color: #E8E0F0;
  --text-secondary: #C4B8D4;
  --text-dim: #9A8EB0;
  --bg-dark: #1A1232;
  --bg-purple: #221A3A;
  --bg-card: rgba(40, 30, 65, 0.75);
  --bg-card-light: rgba(155, 142, 196, 0.1);
  --border-glow: rgba(155, 142, 196, 0.3);
  --pink-soft: rgba(212, 165, 201, 0.35);
  --white: #F0ECF8;
  --danger: #D4534B;

  background: var(--bg-dark);
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica,
    'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei UI', 'Microsoft YaHei',
    Arial, sans-serif;
  font-size: 28rpx;
  color: var(--text-color);
  box-sizing: border-box;
  overflow-x: hidden;
}

/* 淡紫星空渐变背景 */
page::before {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg, 
    #1E1538 0%, 
    #261D45 20%, 
    #2E2450 40%, 
    #362B5C 60%, 
    #3D3268 80%, 
    #453974 100%
  );
  z-index: -2;
  pointer-events: none;
}

/* 星空光斑 + 星尘效果 */
page::after {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
  pointer-events: none;
  background:
    radial-gradient(1rpx 1rpx at 10% 15%, rgba(255,255,255,0.7) 0%, transparent 100%),
    radial-gradient(1rpx 1rpx at 25% 8%, rgba(255,255,255,0.5) 0%, transparent 100%),
    radial-gradient(2rpx 2rpx at 40% 22%, rgba(200,180,255,0.6) 0%, transparent 100%),
    radial-gradient(1rpx 1rpx at 55% 5%, rgba(255,255,255,0.5) 0%, transparent 100%),
    radial-gradient(1rpx 1rpx at 70% 18%, rgba(255,255,255,0.6) 0%, transparent 100%),
    radial-gradient(2rpx 2rpx at 85% 12%, rgba(212,165,201,0.5) 0%, transparent 100%),
    radial-gradient(1rpx 1rpx at 15% 35%, rgba(255,255,255,0.4) 0%, transparent 100%),
    radial-gradient(1rpx 1rpx at 30% 42%, rgba(255,255,255,0.5) 0%, transparent 100%),
    radial-gradient(2rpx 2rpx at 50% 38%, rgba(180,160,230,0.5) 0%, transparent 100%),
    radial-gradient(1rpx 1rpx at 65% 32%, rgba(255,255,255,0.4) 0%, transparent 100%),
    radial-gradient(1rpx 1rpx at 80% 45%, rgba(255,255,255,0.5) 0%, transparent 100%),
    radial-gradient(1rpx 1rpx at 92% 40%, rgba(255,255,255,0.4) 0%, transparent 100%),
    radial-gradient(2rpx 2rpx at 8% 58%, rgba(200,180,255,0.5) 0%, transparent 100%),
    radial-gradient(1rpx 1rpx at 22% 65%, rgba(255,255,255,0.4) 0%, transparent 100%),
    radial-gradient(1rpx 1rpx at 38% 55%, rgba(255,255,255,0.5) 0%, transparent 100%),
    radial-gradient(1rpx 1rpx at 55% 62%, rgba(255,255,255,0.3) 0%, transparent 100%),
    radial-gradient(2rpx 2rpx at 72% 58%, rgba(212,165,201,0.4) 0%, transparent 100%),
    radial-gradient(1rpx 1rpx at 88% 52%, rgba(255,255,255,0.4) 0%, transparent 100%),
    radial-gradient(1rpx 1rpx at 18% 78%, rgba(255,255,255,0.3) 0%, transparent 100%),
    radial-gradient(2rpx 2rpx at 35% 82%, rgba(180,160,230,0.4) 0%, transparent 100%),
    radial-gradient(1rpx 1rpx at 48% 75%, rgba(255,255,255,0.4) 0%, transparent 100%),
    radial-gradient(1rpx 1rpx at 62% 85%, rgba(255,255,255,0.3) 0%, transparent 100%),
    radial-gradient(1rpx 1rpx at 78% 72%, rgba(255,255,255,0.5) 0%, transparent 100%),
    radial-gradient(2rpx 2rpx at 90% 80%, rgba(200,180,255,0.4) 0%, transparent 100%),
    radial-gradient(1rpx 1rpx at 5% 92%, rgba(255,255,255,0.3) 0%, transparent 100%),
    radial-gradient(1rpx 1rpx at 42% 95%, rgba(255,255,255,0.4) 0%, transparent 100%),
    radial-gradient(1rpx 1rpx at 68% 90%, rgba(255,255,255,0.3) 0%, transparent 100%),
    radial-gradient(2rpx 2rpx at 95% 88%, rgba(212,165,201,0.3) 0%, transparent 100%),
    radial-gradient(circle at 15% 25%, rgba(155, 142, 196, 0.08) 0%, transparent 50%),
    radial-gradient(circle at 85% 40%, rgba(212, 165, 201, 0.1) 0%, transparent 45%),
    radial-gradient(circle at 50% 70%, rgba(196, 142, 196, 0.06) 0%, transparent 50%);
}

/* ==================== 闪烁星星 ==================== */
.twinkle-star {
  position: absolute;
  border-radius: 50%;
  background: #fff;
  opacity: 0.15;
  animation: twinkle 2s ease-in-out infinite;
}

