.ts-8  { top: 55%; left: 88%; width: 4rpx; height: 4rpx; opacity: 0.5; animation: twinkle-b 3.9s 0.9s ease-in-out infinite; box-shadow: 0 0 8rpx 2rpx rgba(200,180,255,0.3); }
.ts-9  { top: 62%; left: 42%; width: 5rpx; height: 5rpx; opacity: 0.6; animation: twinkle-c 4.5s 1.6s ease-in-out infinite; box-shadow: 0 0 12rpx 3rpx rgba(255,255,255,0.4); }
.ts-10 { top: 70%; left: 15%; width: 3rpx; height: 3rpx; opacity: 0.35; animation: twinkle-a 5.6s 0.6s ease-in-out infinite; box-shadow: 0 0 6rpx 2rpx rgba(212,165,201,0.25); }
.ts-11 { top: 76%; left: 72%; width: 4rpx; height: 4rpx; opacity: 0.45; animation: twinkle-b 6.4s 2.1s ease-in-out infinite; box-shadow: 0 0 8rpx 2rpx rgba(255,255,255,0.3); }
