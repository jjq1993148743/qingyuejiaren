/* custom-tab-bar/index.wxss */

.tab-bar {
  display: flex;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 110rpx;
  background: rgba(26, 0, 51, 0.95);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-top: 1rpx solid rgba(155, 109, 255, 0.2);
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 500;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  transition: all 0.2s;
}

.tab-icon {
  font-size: 40rpx;
  transition: all 0.2s;
}

.tab-text {
  font-size: 20rpx;
  color: #8B7DAF;
  transition: all 0.2s;
}

.tab-item.active .tab-text {
  color: #E8B4D8;
}

.tab-item.active .tab-icon {
  transform: scale(1.1);
}
