/* custom-tab-bar/index.wxss - 粉色轻奢主题 */

.tab-bar {
  display: flex;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 110rpx;
  background: rgba(26, 18, 50, 0.92);
  border-top: 1rpx solid rgba(240, 184, 198, 0.15);
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 500;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  transition: all 0.2s;
}

.icon-box {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

/* ===== 故事墙：三条竖线 ===== */
.icon-bars {
  display: flex;
  align-items: flex-end;
  gap: 6rpx;
  height: 36rpx;
}

.icon-bars .bar {
  width: 6rpx;
  border-radius: 3rpx;
  background: #D4B0C0;
  transition: all 0.2s;
}

.icon-bars .bar:nth-child(1) { height: 20rpx; }
.icon-bars .bar:nth-child(2) { height: 32rpx; }
.icon-bars .bar:nth-child(3) { height: 26rpx; }

.tab-item.active .icon-bars .bar {
  background: #FFD0DC;
}

/* ===== 愿望清单：圆+勾 ===== */
.icon-check-circle {
  width: 36rpx;
  height: 36rpx;
  border: 3rpx solid #D4B0C0;
  border-radius: 50%;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.check-mark {
  width: 14rpx;
  height: 8rpx;
  border-left: 3rpx solid #D4B0C0;
  border-bottom: 3rpx solid #D4B0C0;
  transform: rotate(-45deg) translateY(-4rpx);
  transition: all 0.2s;
}

.tab-item.active .icon-check-circle {
  border-color: #FFD0DC;
  background: rgba(255, 208, 220, 0.2);
  box-shadow: 0 0 16rpx rgba(255, 208, 220, 0.4);
}

.tab-item.active .check-mark {
  border-color: #FFD0DC;
}

/* ===== 小日子：日历 ===== */
.icon-calendar {
  width: 34rpx;
  height: 34rpx;
  border: 3rpx solid #D4B0C0;
  border-radius: 6rpx;
  padding: 6rpx 4rpx 4rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  transition: all 0.2s;
}

.cal-header {
  width: 100%;
  height: 3rpx;
  background: #D4B0C0;
  border-radius: 2rpx;
}

.cal-dots {
  display: flex;
  gap: 6rpx;
}

.cal-dot {
  width: 5rpx;
  height: 5rpx;
  border-radius: 50%;
  background: #D4B0C0;
}

.tab-item.active .icon-calendar {
  border-color: #FFD0DC;
  background: rgba(255, 208, 220, 0.2);
  box-shadow: 0 0 16rpx rgba(255, 208, 220, 0.4);
}

.tab-item.active .cal-header,
.tab-item.active .cal-dot {
  background: #FFD0DC;
}

/* ===== 文字 ===== */
.tab-text {
  font-size: 20rpx;
  color: #D4B0C0;
  transition: all 0.2s;
  letter-spacing: 1rpx;
}

.tab-item.active .tab-text {
  color: #FFD0DC;
}
