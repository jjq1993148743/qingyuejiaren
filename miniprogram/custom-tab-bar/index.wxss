/* custom-tab-bar/index.wxss - 粉色轻奢主题 */

/* ===== 闪烁星星 ===== */
.twinkle-star {
  position: absolute;
  border-radius: 50%;
  background: #fff;
  opacity: 0.3;
}

/* 18颗星 - 错落节奏：大部分时间微亮，偶尔闪烁一下 */
.ts-1  { top: 6%;  left: 10%; width: 4rpx; height: 4rpx; opacity: 0.4; animation: twinkle-a 4.2s 0.0s ease-in-out infinite; box-shadow: 0 0 8rpx 2rpx rgba(255,255,255,0.3); }
.ts-2  { top: 12%; left: 75%; width: 3rpx; height: 3rpx; opacity: 0.5; animation: twinkle-b 5.8s 0.7s ease-in-out infinite; box-shadow: 0 0 6rpx 2rpx rgba(200,180,255,0.3); }
.ts-3  { top: 18%; left: 38%; width: 5rpx; height: 5rpx; opacity: 0.6; animation: twinkle-c 3.5s 1.2s ease-in-out infinite; box-shadow: 0 0 12rpx 3rpx rgba(200,180,255,0.4); }
.ts-4  { top: 25%; left: 90%; width: 3rpx; height: 3rpx; opacity: 0.35; animation: twinkle-a 6.1s 0.3s ease-in-out infinite; box-shadow: 0 0 6rpx 2rpx rgba(255,255,255,0.25); }
.ts-5  { top: 33%; left: 5%;  width: 4rpx; height: 4rpx; opacity: 0.45; animation: twinkle-b 4.7s 1.8s ease-in-out infinite; box-shadow: 0 0 8rpx 2rpx rgba(255,255,255,0.3); }
