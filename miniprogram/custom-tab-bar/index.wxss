.ts-13 { top: 3%;  left: 50%; width: 4rpx; height: 4rpx; opacity: 0.4; animation: twinkle-a 5.1s 2.8s ease-in-out infinite; box-shadow: 0 0 8rpx 2rpx rgba(255,255,255,0.3); }
.ts-14 { top: 35%; left: 95%; width: 3rpx; height: 3rpx; opacity: 0.35; animation: twinkle-b 3.7s 1.0s ease-in-out infinite; box-shadow: 0 0 6rpx 2rpx rgba(212,165,201,0.25); }
.ts-15 { top: 58%; left: 8%;  width: 4rpx; height: 4rpx; opacity: 0.45; animation: twinkle-c 6.8s 1.5s ease-in-out infinite; box-shadow: 0 0 8rpx 2rpx rgba(255,255,255,0.3); }
.ts-16 { top: 88%; left: 30%; width: 3rpx; height: 3rpx; opacity: 0.3; animation: twinkle-a 4.4s 0.4s ease-in-out infinite; box-shadow: 0 0 6rpx 2rpx rgba(200,180,255,0.2); }
.ts-17 { top: 45%; left: 48%; width: 5rpx; height: 5rpx; opacity: 0.55; animation: twinkle-b 3.2s 2.6s ease-in-out infinite; box-shadow: 0 0 12rpx 3rpx rgba(255,255,255,0.4); }
.ts-18 { top: 92%; left: 82%; width: 3rpx; height: 3rpx; opacity: 0.3; animation: twinkle-c 5.9s 0.8s ease-in-out infinite; box-shadow: 0 0 6rpx 2rpx rgba(212,165,201,0.2); }

/* A类：缓慢微闪 - 大部分时间亮着，偶尔暗一下 */
@keyframes twinkle-a {
  0%, 100% { opacity: 0.4; }
  40%      { opacity: 0.5; }
  50%      { opacity: 0.15; }
  55%      { opacity: 0.9; }
  60%      { opacity: 0.45; }
}

/* B类：中等闪烁 - 偶尔亮一下 */
@keyframes twinkle-b {
  0%, 100% { opacity: 0.3; }
  30%      { opacity: 0.35; }
  45%      { opacity: 0.1; }
  48%      { opacity: 0.85; }
  52%      { opacity: 0.2; }
  70%      { opacity: 0.4; }
  85%      { opacity: 0.15; }
  88%      { opacity: 0.75; }
  92%      { opacity: 0.35; }
}

/* C类：快速闪亮 - 突然亮起再慢慢暗 */
@keyframes twinkle-c {
  0%, 100% { opacity: 0.35; }
  20%      { opacity: 0.4; }
  35%      { opacity: 0.2; }
  38%      { opacity: 1; }
  42%      { opacity: 0.3; }
  65%      { opacity: 0.5; }
  75%      { opacity: 0.15; }
  78%      { opacity: 0.9; }
  82%      { opacity: 0.4; }
}

/* ===== 流星效果 ===== */
.meteor-layer {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
  pointer-events: none;
  overflow: hidden;
}

.meteor {
  position: absolute;
  width: 6rpx;
  height: 6rpx;
  background: #fff;
  border-radius: 50%;
  box-shadow: 0 0 8rpx 3rpx rgba(255,255,255,0.8), 0 0 20rpx 6rpx rgba(200,180,255,0.4);
  opacity: 0;
}

.meteor::after {
  content: '';
  position: absolute;
  top: 50%;
  right: 50%;
  width: 160rpx;
  height: 2rpx;
  transform: translateY(-50%);
  background: linear-gradient(to left, rgba(255,255,255,0.7), rgba(200,180,255,0.3) 40%, transparent);
  border-radius: 1rpx;
}

.meteor-1 {
  top: 2%;
  left: 10%;
  animation: meteor1 8s 0s linear infinite;
}

.meteor-2 {
  top: 0%;
  left: 50%;
  animation: meteor2 10s 3s linear infinite;
}

.meteor-3 {
  top: 5%;
  left: 75%;
  animation: meteor3 9s 6s linear infinite;
}

@keyframes meteor1 {
  0%   { opacity: 0; transform: rotate(-35deg) translate(0, 0); }
  3%   { opacity: 1; }
  25%  { opacity: 1; }
  35%  { opacity: 0; transform: rotate(-35deg) translate(900rpx, 0); }
  100% { opacity: 0; transform: rotate(-35deg) translate(900rpx, 0); }
}

@keyframes meteor2 {
  0%   { opacity: 0; transform: rotate(-35deg) translate(0, 0); }
  3%   { opacity: 1; }
  20%  { opacity: 1; }
  30%  { opacity: 0; transform: rotate(-35deg) translate(1000rpx, 0); }
  100% { opacity: 0; transform: rotate(-35deg) translate(1000rpx, 0); }
}

@keyframes meteor3 {
  0%   { opacity: 0; transform: rotate(-35deg) translate(0, 0); }
  3%   { opacity: 1; }
  22%  { opacity: 1; }
  32%  { opacity: 0; transform: rotate(-35deg) translate(850rpx, 0); }
  100% { opacity: 0; transform: rotate(-35deg) translate(850rpx, 0); }
}

/* ===== Tab栏 ===== */

.tab-bar {
  display: flex;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 110rpx;
  background: rgba(26, 18, 50, 0.92);
  border-top: 1rpx solid rgba(240, 184, 198, 0.15);
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 500;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  transition: all 0.2s;
}

.icon-box {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

/* ===== 故事墙：翻开的书 ===== */
.icon-book {
  position: relative;
  width: 36rpx;
  height: 28rpx;
  display: flex;
  justify-content: center;
}

.book-left, .book-right {
  width: 15rpx;
  height: 26rpx;
  border: 2rpx solid #D4B0C0;
  border-radius: 3rpx 0 0 3rpx;
  background: transparent;
  transition: all 0.2s;
}

.book-right {
  border-radius: 0 3rpx 3rpx 0;
}

.book-spine {
  position: absolute;
  width: 2rpx;
  height: 28rpx;
  background: #D4B0C0;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  transition: all 0.2s;
}

.book-left {
  transform: perspective(60rpx) rotateY(8deg);
}

.book-right {
  transform: perspective(60rpx) rotateY(-8deg);
}

.tab-item.active .book-left,
.tab-item.active .book-right {
  border-color: #FFD0DC;
  background: rgba(255, 208, 220, 0.15);
}

.tab-item.active .book-spine {
  background: #FFD0DC;
}

/* ===== 愿望清单：许愿星 ===== */
.icon-wish-star {
  position: relative;
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.star-body {
  width: 22rpx;
  height: 22rpx;
  background: #D4B0C0;
  clip-path: polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%);
  transition: all 0.2s;
}

.star-tail {
  position: absolute;
  width: 20rpx;
  height: 2rpx;
  background: linear-gradient(90deg, #D4B0C0, transparent);
  bottom: 8rpx;
  right: 4rpx;
  transform: rotate(-30deg);
  transition: all 0.2s;
}

.tab-item.active .star-body {
  background: #FFD0DC;
  box-shadow: 0 0 12rpx rgba(255, 208, 220, 0.5);
}

.tab-item.active .star-tail {
  background: linear-gradient(90deg, #FFD0DC, transparent);
}

/* ===== 小日子：日历 ===== */
.icon-calendar {
  position: relative;
  width: 36rpx;
  height: 34rpx;
  display: flex;
  justify-content: center;
}

.cal-body {
  width: 34rpx;
  height: 28rpx;
  border: 2rpx solid #D4B0C0;
  border-radius: 5rpx;
  margin-top: 6rpx;
  overflow: hidden;
  transition: all 0.2s;
}

.cal-header-bar {
  width: 100%;
  height: 6rpx;
  background: #D4B0C0;
  transition: all 0.2s;
}

.cal-dots {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  padding: 4rpx 4rpx 0;
  gap: 5rpx;
}

.cal-dot {
  width: 4rpx;
  height: 4rpx;
  border-radius: 50%;
  background: #D4B0C0;
  transition: all 0.2s;
}

.cal-ring {
  position: absolute;
  width: 6rpx;
  height: 8rpx;
  border: 2rpx solid #D4B0C0;
  border-bottom: none;
  border-radius: 3rpx 3rpx 0 0;
  top: 0;
  transition: all 0.2s;
}

.cal-ring-left {
  left: 6rpx;
}

.cal-ring-right {
  right: 6rpx;
}

.tab-item.active .cal-body {
  border-color: #FFD0DC;
  background: rgba(255, 208, 220, 0.1);
}

.tab-item.active .cal-header-bar {
  background: #FFD0DC;
}

.tab-item.active .cal-dot {
  background: #FFD0DC;
}

.tab-item.active .cal-ring {
  border-color: #FFD0DC;
}

/* ===== 文字 ===== */
.tab-text {
  font-size: 20rpx;
  color: #D4B0C0;
  transition: all 0.2s;
  letter-spacing: 1rpx;
}

.tab-item.active .tab-text {
  color: #FFD0DC;
}
